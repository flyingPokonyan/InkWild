# 运行环境标识，影响日志/Sentry behavior
ENVIRONMENT=development
# 部署版本号，注入 Sentry release 标签
RELEASE_TAG=
# Sentry DSN（旧字段，向后兼容）
SENTRY_DSN=
# Sentry DSN（后端专用，优先级高于 SENTRY_DSN）
BACKEND_SENTRY_DSN=

# 数据库连接（异步驱动）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inkwild
# SQLAlchemy pool 大小
DB_POOL_SIZE=5
# pool overflow 上限
DB_MAX_OVERFLOW=10
# 获取连接的超时秒数
DB_POOL_TIMEOUT=30

# Redis 连接（session lock + rate limit）
REDIS_URL=redis://localhost:6379/0

# 默认 LLM provider key（model_slots 优先；这里仅作 fallback）
LLM_PROVIDER=deepseek
# Anthropic Claude API Key
ANTHROPIC_API_KEY=
# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DeepSeek API Base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 默认对话模型
LLM_DEFAULT_MODEL=deepseek-chat
# 上下文压缩用模型（cheap tier 即可）
LLM_COMPRESSION_MODEL=deepseek-chat

# 单局对话最多保留多少轮原文（超出走 compressor）
MAX_CONTEXT_ROUNDS=15
# 触发压缩的阈值（轮数）
COMPRESSION_THRESHOLD=20
# SessionLock TTL（秒）
SESSION_LOCK_TIMEOUT=60
# LLM 内容审核开关
CONTENT_FILTER_ENABLED=true
# 调试开关（启用更详细日志、关闭部分缓存等）
DEBUG=true

# Cookie session 名（不要随便改）
AUTH_COOKIE_NAME=inkwild_session
# session cookie 有效期（天）
WEB_SESSION_DAYS=90
# 开发环境是否启用本地用户名密码登录
ENABLE_DEV_AUTH=false
# 开发用户邮箱（仅 ENABLE_DEV_AUTH=true 生效）
DEV_USER_EMAIL=you@example.com
# 开发用户密码 hash（scrypt 编码）
DEV_USER_PASSWORD_HASH=
# session cookie 作用域；prod 跨子域时设 .inkwild.app，dev 留空
SESSION_COOKIE_DOMAIN=

# ── 用户认证：邮箱注册/验证/重置 + OAuth ───────────────────────────
# 邮件后端：console=打日志不真发（dev）｜resend=真发（prod）
EMAIL_BACKEND=console
# Resend API Key（EMAIL_BACKEND=resend 时必填）；resend.com 申请，需先验证发信域名 + 配 SPF/DKIM
RESEND_API_KEY=
# 发件地址（必须属于已在 Resend 验证的域名）
EMAIL_FROM=InkWild <noreply@inkwild.app>
# 前端站点根 URL，用于拼验证/重置邮件里的链接
PUBLIC_WEB_URL=http://localhost:3000
# 后端公网根 URL，用于拼 OAuth 回调；必须与各 provider 后台登记的回调域名一致
PUBLIC_API_URL=http://localhost:8000
# starlette SessionMiddleware 密钥（仅承载 OAuth state）；prod 必须换成随机串
SESSION_SECRET_KEY=dev-insecure-change-me
# Google OAuth（console.cloud.google.com 建 Web 客户端；回调 {PUBLIC_API_URL}/api/auth/oauth/google/callback）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# LinuxDo OAuth（connect.linux.do 申请；回调 {PUBLIC_API_URL}/api/auth/oauth/linuxdo/callback）
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=
# 令牌有效期（秒）：邮箱验证 24h / 密码重置 1h / OAuth state 10min
EMAIL_VERIFY_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
OAUTH_STATE_TTL_SECONDS=600
# auth 端点限流（按 IP/邮箱滑窗）：窗口内最多次数 / 窗口秒数
AUTH_RATE_LIMIT_PER_WINDOW=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=300

# 创世/搜索：Tavily 联网检索
TAVILY_API_KEY=tvly-xxx

# Grok / xAI（文本 + 图像）
GROK_API_KEY=xai-xxx
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.20-0309-reasoning
GROK_IMAGE_MODEL=grok-imagine-image

# gpt-image 生图（OpenAI 兼容端点，默认绑定 image_generation slot）
# 留空则回退到 GROK_IMAGE_MODEL
GPTIMAGE_API_KEY=
GPTIMAGE_BASE_URL=https://gptimage.pokonyan.com/v1
GPTIMAGE_IMAGE_MODEL=gpt-image-2

# Gemini OpenAI 兼容端点（v1beta/openai）
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 模型探测结果缓存时长（小时）
MODEL_PROBE_TTL_HOURS=168
# 启动时是否自动 bootstrap 内置 provider/slot
MODEL_MANAGEMENT_BOOTSTRAP_ENABLED=true

# 图片存储后端 local|oss
IMAGE_STORAGE_BACKEND=local
# 本地图片存储目录（IMAGE_STORAGE_BACKEND=local 时生效）
IMAGE_STORAGE_DIR=static/images

# 阿里云 OSS（IMAGE_STORAGE_BACKEND=oss 时必填）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=
OSS_KEY_PREFIX=inkwild/images

# 单局成本提醒阈值（分）
GAME_SESSION_SOFT_WARN_COST_CENTS=500
# 单局成本硬上限（分），超过则中断
GAME_SESSION_HARD_CAP_COST_CENTS=600
# input token 单价（cents per million tokens），用于成本估算
GAME_INPUT_COST_CENTS_PER_MILLION_TOKENS=0
# output token 单价（cents per million tokens）
GAME_OUTPUT_COST_CENTS_PER_MILLION_TOKENS=0
# 玩家单分钟动作次数上限
GAME_ACTION_RATE_LIMIT_PER_MINUTE=30
# rate limit 窗口长度（秒）
GAME_ACTION_RATE_LIMIT_WINDOW_SECONDS=60

# Director Agent 是否优先用 JSON mode（部分 provider 不支持）
DIRECTOR_PREFER_JSON_MODE=false
# Narrator Agent 提前流式开关
NARRATOR_EARLY_STREAM_ENABLED=true

# 语义记忆 embedding（OpenAI 兼容 API）；默认关闭
EMBEDDING_ENABLED=false
# embedding 服务 base url
EMBEDDING_BASE_URL=
# embedding 服务 API key
EMBEDDING_API_KEY=
# embedding 模型名
EMBEDDING_MODEL=text-embedding-3-small
# embedding 向量维度
EMBEDDING_DIM=1536
# 单次 embedding 调用硬超时（秒）
EMBEDDING_TIMEOUT_SECONDS=5.0

# NPC 长期反思（积累若干 memory 条后聚合一次）
NPC_REFLECTION_ENABLED=true
# 触发反思所需的新 memory 条数
NPC_REFLECTION_THRESHOLD=5
# 单回合 NPC LLM 并发上限（防止 rate limit）
NPC_MAX_CONCURRENCY=6
# NPC 群体顺序对话开关（关 = 退化为并行 gather）
NPC_DIALOGUE_SEQUENTIAL_ENABLED=true
# 单回合最多发声 NPC 数（防止 wall-time 爆炸）
NPC_MAX_SPEAKERS_PER_TURN=3
# NPC 之间持久关系开关（read-only first pass）
NPC_PEER_RELATIONS_ENABLED=true

# 浏览器侧调用的后端 API 地址（公开，会注入到客户端 bundle）
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side admin 代理用的后端地址（容器内部网络 / Server Actions），缺省时回落到 NEXT_PUBLIC_API_URL
INTERNAL_API_URL=
# 前端 Sentry DSN（公开）
NEXT_PUBLIC_SENTRY_DSN=
# Sentry 上传 sourcemap 的 token（仅 build 阶段使用）
SENTRY_AUTH_TOKEN=
# Sentry 组织 slug
SENTRY_ORG=
# Sentry 项目 slug
SENTRY_PROJECT=
